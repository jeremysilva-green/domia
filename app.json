{
  "expo": {
    "name": "Domia",
    "slug": "domus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Domia Splash.png",
    "scheme": "domus",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Domia Splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.domus.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Domia Splash.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.domus.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#1a1a2e"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Domus to access your photos for maintenance requests."
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4a116f40-1165-4ef4-b408-4ba19f4b246e"
      }
    }
  }
}
